{
  "name": "fontaine-project",
  "private": true,
  "workspaces": [
    "modules/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "bun run --workspaces test",
    "dev": "bun --hot apps/preview-server/src/server.ts --file test.fountain",
    "compile:preview-server": "bun run --filter fontaine-preview-server compile"
  },
  "devDependencies": {
    "typescript": "latest",
    "bun-types": "latest"
  }
}
